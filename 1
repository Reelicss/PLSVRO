-- LocalScript in StarterPlayerScripts

local Workspace = game:GetService("Workspace")

local function applyGreyscale(part)
    if part:IsA("BasePart") or part:IsA("Terrain") then
        local char = game.Players.LocalPlayer.Character
        if char and part:IsDescendantOf(char) then return end

        if part:IsA("Terrain") then
            part.WaterColor = Color3.fromRGB(60, 60, 60)
        else
            local c = part.Color
            local grey = (0.299 * c.R + 0.587 * c.G + 0.114 * c.B) * 0.4
            part.Color = Color3.new(grey, grey, grey)
        end
    end
end

for _, obj in ipairs(Workspace:GetDescendants()) do
    applyGreyscale(obj)
end

Workspace.DescendantAdded:Connect(applyGreyscale)

